# ─────────────────────────────────────────────────────────────
# 서버(BFF) 환경변수 예시 — .env 로 복사해서 실제 값 채우기 (.env 는 커밋 금지)
# 여기 키들은 서버에서만 사용되며 클라이언트 번들에 절대 포함되지 않는다 (VITE_ 접두사 금지).
# ─────────────────────────────────────────────────────────────

# 외부 API 키 (서버 전용)
GEMINI_API_KEY=
# 사용할 Gemini 모델 (미설정 시 gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash
SEMANTIC_SCHOLAR_API_KEY=

# 관심분야/요약 영구 저장용 MongoDB (Atlas 권장: https://cloud.mongodb.com → Connect → Drivers)
# 비워두면 인메모리 폴백으로 동작(개발용, 재시작 시 초기화)
MONGODB_URI=
MONGODB_DB=paper_rec

# 로컬 dev 서버 포트 (client의 vite proxy 대상과 일치시킬 것)
PORT=3000

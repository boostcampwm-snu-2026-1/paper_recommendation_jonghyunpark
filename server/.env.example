# ─────────────────────────────────────────────────────────────
# 서버(BFF) 환경변수 예시 — .env 로 복사해서 실제 값 채우기 (.env 는 커밋 금지)
# 여기 키들은 서버에서만 사용되며 클라이언트 번들에 절대 포함되지 않는다 (VITE_ 접두사 금지).
# ─────────────────────────────────────────────────────────────

# 외부 API 키 (서버 전용)
GEMINI_API_KEY=
SEMANTIC_SCHOLAR_API_KEY=

# 관심분야 저장용 Upstash Redis (https://console.upstash.com → Redis DB 생성 → REST 탭)
# 비워두면 인메모리 폴백으로 동작(개발용, 재시작 시 초기화)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# 로컬 dev 서버 포트 (client의 vite proxy 대상과 일치시킬 것)
PORT=3000

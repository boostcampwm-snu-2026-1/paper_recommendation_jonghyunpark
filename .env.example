# ─────────────────────────────────────────────────────────────
# 환경변수 예시 (.env 로 복사해서 실제 값 채우기 — .env 는 커밋 금지)
# ─────────────────────────────────────────────────────────────

# 서버(BFF) 전용 키 — 절대 VITE_ 접두사 금지 (붙이면 클라이언트 번들에 노출됨)
GEMINI_API_KEY=
SEMANTIC_SCHOLAR_API_KEY=

# 클라이언트에서 접근 가능한 값만 VITE_ 접두사 사용
# 예) BFF 베이스 URL (기본은 동일 오리진 /api)
VITE_API_BASE_URL=/api
